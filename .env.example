# Copy to .env for local overrides. Do not commit real secrets.
# These mirror the Coordinator's CTV_* settings; docker-compose.yml sets its own values.

CTV_LISTEN_ADDR=:8080
CTV_DATABASE_URL=postgres://calltoverify:calltoverify@localhost:5432/calltoverify?sslmode=disable
CTV_REDIS_URL=redis://localhost:6379
CTV_ENV=development
