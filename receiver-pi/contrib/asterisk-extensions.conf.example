; Example Asterisk dialplan for the CallToVerify missed-call and DTMF channels.
; Assumes inbound calls from your GSM modem (e.g. chan_dongle) land in this context.

[calltoverify-incoming]
; --- Missed-call channel: capture the caller id, hang up immediately (free for
;     the caller), and report it as an inbound 'call' with an empty body. ---
; The caller id is read inside the AGI script from the AGI environment, never
; passed through a shell — a spoofed/crafted caller id cannot inject commands.
; Do NOT use System(... "${CALLERID(num)}"): caller id is attacker-controlled.
exten => s,1,NoOp(CallToVerify missed call from ${CALLERID(num)})
 same => n,AGI(/opt/calltoverify/agi/ctv_oncall.py)
 same => n,Hangup()

; --- DTMF channel: answer and collect the code via the AGI script. ---
; To use DTMF instead of missed-call, route to this extension instead of 's':
exten => dtmf,1,NoOp(CallToVerify DTMF from ${CALLERID(num)})
 same => n,AGI(/opt/calltoverify/agi/ctv_dtmf.py)
 same => n,Hangup()
