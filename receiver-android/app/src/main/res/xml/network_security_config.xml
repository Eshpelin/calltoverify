<?xml version="1.0" encoding="utf-8"?>
<!-- Release/production: deny cleartext to every domain. A receiver must reach the
     Coordinator over HTTPS (the device HMAC gives integrity + auth, but only TLS
     keeps the sender number and code confidential on the wire).
     The debug build overrides this with localhost / emulator-host exceptions for
     local testing — see src/debug/res/xml/network_security_config.xml. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
