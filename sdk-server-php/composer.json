{
    "name": "calltoverify/sdk",
    "description": "Server SDK for CallToVerify — free, self-hosted phone number verification.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["otp", "phone-verification", "2fa", "sms", "calltoverify", "laravel"],
    "homepage": "https://github.com/Eshpelin/calltoverify",
    "authors": [
        { "name": "The CallToVerify Authors" }
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "CallToVerify\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CallToVerify\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "CallToVerify\\Laravel\\CallToVerifyServiceProvider"
            ],
            "aliases": {
                "CallToVerify": "CallToVerify\\Laravel\\CallToVerifyFacade"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
